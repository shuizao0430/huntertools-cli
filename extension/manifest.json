{
  "manifest_version": 3,
  "name": "HunterTools Browser Bridge",
  "version": "1.5.5",
  "description": "Browser automation bridge for HunterToolsCLI. Executes commands in isolated Chrome windows via a local daemon.",
  "permissions": [
    "debugger",
    "scripting",
    "tabs",
    "cookies",
    "activeTab",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "HunterToolsCLI",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "homepage_url": "https://github.com/shuizao0430/huntertools-cli"
}
